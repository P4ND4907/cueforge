{
  "name": "cueforge",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first FPS audio testing and tuning suite.",
  "author": "P4ND4907",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "desktop:dir": "npm run build && electron-builder --dir",
    "desktop:package": "npm run build && electron-builder --win portable --x64",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.p4nd4907.cueforge",
    "productName": "CueForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "tools/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false,
      "artifactName": "CueForge-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.7"
  }
}
